{
  "name": "@vygruppen/spor-mcp-server",
  "version": "2.0.1",
  "description": "MCP server for Spor Design System",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "bin": {
    "spor-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test:smoke": "pnpm build && node dist/sdk-client.js",
    "inspect": "pnpm build && npx @modelcontextprotocol/inspector node dist/index.js"
  },
  "keywords": [
    "mcp",
    "spor",
    "design-system"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@sanity/client": "^7.12.0",
    "@vygruppen/spor-design-tokens": "^4.3.2",
    "@vygruppen/spor-react": "^12.24.8",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "typescript": "^5.9.3"
  }
}
