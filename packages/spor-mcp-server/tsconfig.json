{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "SideSpor Config",
  "extends": "../tsconfig/base.json",
  "include": ["index.ts", "sdk-client.ts"],
  "exclude": ["node_modules", "dist"],
  "compilerOptions": {
    "module": "ESNext",
    "target": "es2024",
    "downlevelIteration": true,
    "moduleResolution": "bundler",
    "rootDir": ".",
    "outDir": "dist",
    "types": ["node"]
  }
}
